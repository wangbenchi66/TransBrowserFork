<Window x:Class="TransBrowser.Wpf.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Width="480" Height="640"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="TransBrowser 设置" FontSize="16" FontWeight="Bold"
                   Margin="0,4,0,8" Foreground="#333"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ══ Panel 1: 基础设置 ══════════════════════════════════ -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="基础设置" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" Foreground="#555"/>

                        <!-- 透明度 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="透明度" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" x:Name="SliderOpacity" Minimum="0" Maximum="99"
                                    VerticalAlignment="Center" ValueChanged="SliderOpacity_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="LblOpacityValue"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="11"/>
                        </Grid>

                        <!-- 默认 URL -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="默认URL" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtDefaultUrl" Height="26" Padding="4,2"
                                     VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="加载" Margin="4,0,0,0"
                                    Style="{StaticResource FlatButtonStyle}"
                                    Click="BtnLoadUrl_Click"/>
                        </Grid>

                        <!-- 主题颜色 -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="主题颜色" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Border x:Name="ColorPreview" Width="30" Height="24" CornerRadius="4"
                                        Background="#F9F9F9" BorderBrush="#CCC" BorderThickness="1"
                                        Cursor="Hand" MouseLeftButtonDown="ColorPreview_Click"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="（点击选色）" VerticalAlignment="Center" Margin="6,0,0,0"
                                           FontSize="11" Foreground="#999"/>
                            </StackPanel>
                        </Grid>

                        <!-- Switches -->
                        <ItemsControl x:Name="SwitchesPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Each row is a label + ToggleButton -->
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- All the toggle rows inline -->
                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="失焦自动隐藏" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwAutoHide" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwAutoHide_Changed" Unchecked="SwAutoHide_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="手机模式" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwMobileMold" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwMobileMold_Changed" Unchecked="SwMobileMold_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="显示任务栏图标" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwShowInTaskbar" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwShowInTaskbar_Changed" Unchecked="SwShowInTaskbar_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="显示标签栏" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwShowTabBar" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwShowTabBar_Changed" Unchecked="SwShowTabBar_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="悬停显示标题栏" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwHoverHeader" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwHoverHeader_Changed" Unchecked="SwHoverHeader_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="禁止加载图片" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwNoImage" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwNoImage_Changed" Unchecked="SwNoImage_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="网页透明背景" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwTransparentBg" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwTransparentBg_Changed" Unchecked="SwTransparentBg_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="窗口完全透明" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwWindowTransparent" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwWindowTransparent_Changed" Unchecked="SwWindowTransparent_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="灰度模式" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwGrayscale" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwGrayscale_Changed" Unchecked="SwGrayscale_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="防截屏模式" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwAntiScreenshot" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwAntiScreenshot_Changed" Unchecked="SwAntiScreenshot_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="禁用窗口阴影" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwWindowShadow" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwWindowShadow_Changed" Unchecked="SwWindowShadow_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="最小化通知" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwMinimizeNotify" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwMinimizeNotify_Changed" Unchecked="SwMinimizeNotify_Changed"/></Grid>

                        <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="关闭时隐藏到托盘" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="SwCloseToTray" Grid.Column="1" HorizontalAlignment="Left" Style="{StaticResource SwitchStyle}" Checked="SwCloseToTray_Changed" Unchecked="SwCloseToTray_Changed"/></Grid>

                    </StackPanel>
                </Border>

                <!-- ══ Panel 2: 图标 & User-Agent ════════════════════════ -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="User-Agent / 图标" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" Foreground="#555"/>

                        <!-- UA -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="User-Agent" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Column="1" x:Name="TxtUA" Height="26" Padding="4,2" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="设置" Margin="4,0,0,0"
                                    Style="{StaticResource FlatButtonStyle}" Click="BtnSetUA_Click"/>
                        </Grid>

                        <!-- Icon path -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="自定义图标" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Column="1" x:Name="TxtIconPath" Height="26" Padding="4,2" IsReadOnly="True" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="浏览…" Margin="4,0,0,0"
                                    Style="{StaticResource FlatButtonStyle}" Click="BtnBrowseIcon_Click"/>
                        </Grid>

                        <!-- Preset icons -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="预设图标" VerticalAlignment="Center" FontSize="11"/>
                            <ComboBox Grid.Column="1" x:Name="CmbPresetIcons" Height="26">
                                <ComboBoxItem>Default</ComboBoxItem>
                                <ComboBoxItem>Excel</ComboBoxItem>
                                <ComboBoxItem>Word</ComboBoxItem>
                                <ComboBoxItem>Notepad</ComboBoxItem>
                                <ComboBoxItem>Chrome</ComboBoxItem>
                            </ComboBox>
                            <Button Grid.Column="2" Content="应用" Margin="4,0,0,0"
                                    Style="{StaticResource FlatButtonStyle}" Click="BtnApplyPresetIcon_Click"/>
                            <Button Grid.Column="3" Content="恢复" Margin="4,0,0,0"
                                    Style="{StaticResource FlatButtonStyle}" Click="BtnRestoreIcon_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ══ Panel 3: 全局热键 ══════════════════════════════════ -->
                <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="全局热键（点击输入框后按键）" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" Foreground="#555"/>

                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="老板键（隐藏/显示）" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Column="1" x:Name="TxtBossKey" IsReadOnly="True" Height="26" Padding="4,2"
                                     VerticalContentAlignment="Center" PreviewKeyDown="HotkeyBox_KeyDown"
                                     GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="提高透明度" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Column="1" x:Name="TxtOpacityUp" IsReadOnly="True" Height="26" Padding="4,2"
                                     VerticalContentAlignment="Center" PreviewKeyDown="HotkeyBox_KeyDown"
                                     GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="降低透明度" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Column="1" x:Name="TxtOpacityDown" IsReadOnly="True" Height="26" Padding="4,2"
                                     VerticalContentAlignment="Center" PreviewKeyDown="HotkeyBox_KeyDown"
                                     GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBlock Text="鼠标穿透切换" VerticalAlignment="Center" FontSize="11"/>
                            <TextBox Grid.Column="1" x:Name="TxtClickThrough" IsReadOnly="True" Height="26" Padding="4,2"
                                     VerticalContentAlignment="Center" PreviewKeyDown="HotkeyBox_KeyDown"
                                     GotFocus="HotkeyBox_GotFocus" LostFocus="HotkeyBox_LostFocus"/>
                        </Grid>

                        <Button Content="保存热键" HorizontalAlignment="Right" Margin="0,8,0,0"
                                Style="{StaticResource FlatButtonStyle}" Click="BtnSaveHotkeys_Click"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
